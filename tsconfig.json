{
  "extends": "@homeassistant-extras/config/tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@cards/*": ["./src/cards/*"],
      "@common/*": ["./src/common/*"],
      "@delegates/*": ["./src/delegates/*"],
      "@html/*": ["./src/html/*"],
      "@test/*": ["./test/*"],
      "@type/*": ["./src/types/*"],
      "@util/*": ["./src/util/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
